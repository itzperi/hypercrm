{
  "name": "hypercrm",
  "version": "1.0.0",
  "description": "HyperCRM Operations & Document Auto-Generation Platform",
  "main": "server/index.js",
  "scripts": {
    "init-db": "node server/init-db.js",
    "server": "nodemon server/index.js",
    "client": "npm run dev --prefix client",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "build": "npm run build --prefix client",
    "start": "node server/index.js",
    "export-templates": "node scripts/export-templates.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "puppeteer": "^22.11.2",
    "sqlite3": "^5.1.7"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.1.3"
  }
}
